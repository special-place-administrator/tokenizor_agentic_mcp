/target

# Root-level tool and harness state directories.
# Keep repo-owned dot directories explicitly visible to git.
/.*/
!/.claude/
!/.github/
!/.planning/

npm/*.tgz
.env
.claude/settings.local.json
.claude/circuit-breaker-state.json
.claude/gsd-local-patches/
.claude/get-shit-done/
.claude/gsd-*
.planning/telemetry/*.jsonl
spacetime/*/target/
__pycache__/

# Windows NUL device name — some tools accidentally create a tracked 'nul' file
nul

.octogent
